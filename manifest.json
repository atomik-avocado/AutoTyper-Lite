{
  "manifest_version": 3,
  "name": "AutoTyper Lite",
  "version": "1.0.2",
  "description": "Simulates human-like typing into focused text fields, contenteditable editors, and Google Docs.",
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://mail.google.com/*",
    "https://web.whatsapp.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "AutoTyper Lite",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
