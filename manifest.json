{
  "manifest_version": 3,
  "name": "AutoTyper Lite",
  "version": "1.0.3",
  "description": "Simulates human-like typing into any input field or text area on any webpage",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://*.google.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_icon": {
      "48": "icon.png"
    },
    "default_side_panel": "sidepanel.html"
  },
  "icons": {
    "48": "icon.png"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
